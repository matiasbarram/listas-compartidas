# Base de datos (PostgreSQL local via Docker)
DATABASE_URL="postgresql://listas-user:listas-password@localhost:5432/listas-compartidas?schema=public"

# JWT
JWT_SECRET="jwt-secret-change-in-production"
JWT_EXPIRATION_TIME="30d"

# Encriptación AES-256-CTR (key=32 caracteres, iv=16 caracteres)
ENCRYPTION_KEY="clave-secreta-32-caracteres-aqui"
ENCRYPTION_IV="vector-16-chars!"

# Puerto del backend (opcional, default 8000)
PORT=8000
